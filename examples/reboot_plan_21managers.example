# reboot_plan.conf — FILLED SAMPLE: 21 managers, 7 clusters × 3, 21 days
# =============================================================================
# Copy to reboot_plan.conf on the ORCHESTRATOR VM and swap the IPs for yours.
#   cp examples/reboot_plan_21managers.example reboot_plan.conf
#
# Layout assumed here (edit to match your estate):
#   DC-A : GER1 GER2 GER3 GER4   (12 managers)
#   DC-B : GER5 GER6 GER7        ( 9 managers)
#
# Ordering strategy — ROUND-ROBIN across all 7 clusters:
#   Day 01..07  → the "master" of GER1..GER7   (one per cluster)
#   Day 08..14  → the 2nd  manager of GER1..GER7
#   Day 15..21  → the 3rd  manager of GER1..GER7
# Effect: two managers of the SAME cluster are always 7 days apart, so a
# cluster is never running degraded on consecutive nights. The daily cron
# already gives every reboot a 24h + STABLE-gate settle window on its own;
# the 7-day intra-cluster spacing is defense-in-depth.
#
# Format (parse_reboot_plan): "<DC-LABEL>  <manager-ip>" — one per line.
#   - DC-LABEL must match a [section] in datacenters.conf
#   - manager-ip must exist in that DC jump's managers.conf
#   - inline "# comment" after the IP is fine (stripped before parsing)
# =============================================================================

# ---- Day 01..07 : cluster masters (round 1) --------------------------------
DC-A 192.168.20.10   # GER1-m1
DC-A 192.168.21.10   # GER2-m1
DC-A 192.168.22.10   # GER3-m1
DC-A 192.168.23.10   # GER4-m1
DC-B 192.168.30.10   # GER5-m1
DC-B 192.168.31.10   # GER6-m1
DC-B 192.168.32.10   # GER7-m1

# ---- Day 08..14 : second managers (round 2) --------------------------------
DC-A 192.168.20.11   # GER1-m2
DC-A 192.168.21.11   # GER2-m2
DC-A 192.168.22.11   # GER3-m2
DC-A 192.168.23.11   # GER4-m2
DC-B 192.168.30.11   # GER5-m2
DC-B 192.168.31.11   # GER6-m2
DC-B 192.168.32.11   # GER7-m2

# ---- Day 15..21 : third managers (round 3) ---------------------------------
DC-A 192.168.20.12   # GER1-m3
DC-A 192.168.21.12   # GER2-m3
DC-A 192.168.22.12   # GER3-m3
DC-A 192.168.23.12   # GER4-m3
DC-B 192.168.30.12   # GER5-m3
DC-B 192.168.31.12   # GER6-m3
DC-B 192.168.32.12   # GER7-m3
