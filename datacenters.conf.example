# datacenters.conf.example
#
# Inventory consumed by:
#   bin/run_across_datacenters.sh   (fan-out an automation to every DC)
#   bin/deploy.sh --all-dcs         (sync the toolkit to every DC jump host)
#
# Copy to datacenters.conf (git-ignored) and fill in your jump hosts.
#
# Required fields per section:
#   jump_host   FQDN or IPv4 of the jump VM in that datacenter
#   jump_user   SSH user on the jump VM (alphanumerics + . _ -)
#   repo_path   Absolute path to the nsx-automations checkout on the jump VM
#
# Optional:
#   ssh_key     Private key on THIS host (the orchestrator) used to reach the
#               jump VM. Default: $HOME/.ssh/orchestrator
#               (override globally with NSX_FANOUT_KEY=... in the env)
#
# Field values are validated against a strict regex (IPv4 / FQDN / username /
# absolute path) — shell metacharacters are rejected before they can reach
# ssh or rsync.

# [DC-A]
# jump_host = dc-a-jump.internal.example
# jump_user = netops
# repo_path = /home/netops/nsx-automations
#
# [DC-B]
# jump_host = 10.20.0.50
# jump_user = netops
# repo_path = /home/netops/nsx-automations
# ssh_key   = ~/.ssh/orchestrator_dcb     # different key just for DC-B
#
# [DC-C]
# jump_host = dc-c-jump.internal.example
# jump_user = netops
# repo_path = /opt/nsx-automations
